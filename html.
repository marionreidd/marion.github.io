body{
background:#0b0d1d;
background-image:radial-gradient(rgba(89,217,232,.18) 1px, transparent 1px);
background-size:14px 14px;
}

.card{
background:#14182b;
border:4px solid #080808;
box-shadow:8px 8px 0 #050505;
position:relative;
overflow:hidden;
}

.card::before{
content:'';
position:absolute;
top:-10px;
left:50%;
transform:translateX(-50%) rotate(-4deg);
width:180px;
height:35px;
background:rgba(255,255,255,.12);
backdrop-filter:blur(4px);
}

.profile{
width:100%;
max-width:420px;
display:block;
margin:auto;
border:12px solid #050505;
filter:grayscale(100%) brightness(.55) contrast(1.25);
}

.hero{
padding-top:30px;
}

.hero h1{
font-size:4rem;
line-height:1;
font-family:'Orbitron',sans-serif;
}

.hero h1 .blue{
color:#59d9e8;
}

.label{
font-weight:bold;
letter-spacing:2px;
}
